# Supabase — get from your project dashboard at supabase.com
# These are safe to expose in the browser (Supabase anon key is public by design)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic — add to Netlify's environment variables (Site > Environment Variables)
# NEVER commit this value to git
ANTHROPIC_API_KEY=sk-ant-api03-...
